# Copy to .env.local and fill in values.

# Do not set NODE_ENV in .env.local — breaks production build prerender.
# Next.js sets it automatically per command (dev / build).

DATABASE_URL=postgres://user:pass@host:5432/postgres
DIRECT_URL=postgres://user:pass@host:5432/postgres

AUTH_SESSION_SECRET=change-me-min-32-characters-long-secret
AUTH_SESSION_COOKIE=nexa_session
AUTH_SESSION_TTL_DAYS=14
AUTH_COOKIE_SECURE=false

# Coolify deploy log fetch (scripts/coolify-deploy-log.ts)
# Coolify panel → Keys & Tokens → API token
COOLIFY_BASE_URL=http://91.107.177.182:8000
COOLIFY_API_TOKEN=1|krEyPNBzc2xsaxeyZfum8UICgNWVYRGSfPhVhfAQ60ae9d25
# Application UUID from Coolify app settings URL
COOLIFY_APP_UUID=srpt0a5wfx5ysi2cmu1zsosy

