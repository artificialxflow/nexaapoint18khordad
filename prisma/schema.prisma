generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum UserStatus {
  active
  disabled
}

enum InviteCredentialMode {
  self
  manual
  auto
}

enum AccessLevelPreset {
  full
  sales_only
  finance_only
  custom
}

enum BusinessPlan {
  trial
  active
}

enum BusinessMemberRole {
  owner
  admin
  member
}

enum BusinessStatus {
  active
  archived
}

enum MeizitoApprovalState {
  draft
  pending
  approved
  rejected
  cancelled
}

enum MeizitoApprovalAction {
  approve
  reject
  forward
  comment
  submit
  cancel
}

enum MeizitoMemberRole {
  member
  manager
  senior_manager
}

model SystemRole {
  id          String   @id @default(cuid())
  slug        String   @unique
  nameFa      String
  level       Int
  permissions Json
  isSystem    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  users        User[]
  inviteTokens InviteToken[]
}

model User {
  id                 String            @id @default(cuid())
  username           String            @unique
  passwordHash       String
  displayName        String
  status             UserStatus        @default(active)
  systemRoleId       String
  createdById        String?
  mustChangePassword Boolean           @default(false)
  accessLevelPreset  AccessLevelPreset @default(custom)
  lastLoginAt        DateTime?
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt

  systemRole SystemRole @relation(fields: [systemRoleId], references: [id])
  createdBy  User?      @relation("UserCreatedBy", fields: [createdById], references: [id])
  createdUsers User[]   @relation("UserCreatedBy")

  sessions        Session[]
  invitesCreated  InviteToken[]    @relation("InviteCreatedBy")
  invitesConsumed InviteToken[]    @relation("InviteUsedBy")
  restriction     UserRestriction?
  bankAccess      UserBankAccess[]
  auditLogs       AdminAuditLog[]
  businessesCreated Business[]       @relation("BusinessCreatedBy")
  businessMembers   BusinessMember[]
  managedMemberProfiles BusinessMemberProfile[] @relation("MemberManager")
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  tokenHash String   @unique
  expiresAt DateTime
  ip        String?
  userAgent String?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model InviteToken {
  id                 String               @id @default(cuid())
  tokenHash          String               @unique
  systemRoleId       String
  createdById        String
  expiresAt          DateTime
  usedAt             DateTime?
  usedByUserId       String?
  note               String?
  displayName        String?
  credentialMode     InviteCredentialMode @default(self)
  presetUsername     String?
  presetPasswordHash String?
  createdAt          DateTime             @default(now())

  systemRole SystemRole @relation(fields: [systemRoleId], references: [id])
  createdBy  User       @relation("InviteCreatedBy", fields: [createdById], references: [id])
  usedBy     User?      @relation("InviteUsedBy", fields: [usedByUserId], references: [id])

  @@index([expiresAt])
  @@index([createdById])
}

model PermissionCatalog {
  id        String  @id @default(cuid())
  key       String  @unique
  labelFa   String
  module    String
  sortOrder Int     @default(0)
  isSystem  Boolean @default(true)
}

model UserRestriction {
  id                String   @id @default(cuid())
  userId            String   @unique
  ownSalesOnly      Boolean  @default(false)
  ownPurchaseOnly   Boolean  @default(false)
  timeWindowEnabled Boolean  @default(false)
  allowedFrom       String?
  allowedTo         String?
  updatedAt         DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model BankAccount {
  id        String   @id @default(cuid())
  nameFa    String
  code      String   @unique
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  userAccess UserBankAccess[]
}

model UserBankAccess {
  id            String   @id @default(cuid())
  userId        String
  bankAccountId String
  allowed       Boolean  @default(true)
  updatedAt     DateTime @updatedAt

  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  bankAccount BankAccount @relation(fields: [bankAccountId], references: [id], onDelete: Cascade)

  @@unique([userId, bankAccountId])
  @@index([userId])
}

model AdminAuditLog {
  id         String   @id @default(cuid())
  actorId    String
  action     String
  targetType String
  targetId   String?
  meta       Json?
  createdAt  DateTime @default(now())

  actor User @relation(fields: [actorId], references: [id], onDelete: Cascade)

  @@index([actorId])
  @@index([createdAt])
}

model Business {
  id            String         @id @default(cuid())
  name          String
  plan          BusinessPlan   @default(trial)
  expiresAt     DateTime?
  creditLabel   String         @default("نامحدود")
  defaultLocale String         @default("fa")
  status        BusinessStatus @default(active)
  createdById   String
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  createdBy   User                @relation("BusinessCreatedBy", fields: [createdById], references: [id])
  members     BusinessMember[]
  profile     BusinessProfile?
  fiscalYears FiscalYear[]
  projects    AccountingProject[]

  @@index([status])
  @@index([createdById])
}

model BusinessMember {
  id         String             @id @default(cuid())
  businessId String
  userId     String
  role       BusinessMemberRole @default(member)
  createdAt  DateTime           @default(now())

  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  profile  BusinessMemberProfile?

  @@unique([businessId, userId])
  @@index([userId])
}

model BusinessMemberProfile {
  memberId      String            @id
  jobTitle      String            @default("")
  department    String            @default("")
  mobile        String            @default("")
  extension     String            @default("")
  managerUserId String?
  meizitoRole   MeizitoMemberRole @default(member)
  updatedAt     DateTime          @updatedAt

  member  BusinessMember @relation(fields: [memberId], references: [id], onDelete: Cascade)
  manager User?          @relation("MemberManager", fields: [managerUserId], references: [id], onDelete: SetNull)

  @@index([managerUserId])
  @@index([department])
}

model BusinessProfile {
  businessId   String   @id
  legalName    String   @default("")
  tradeName    String   @default("")
  nationalId   String   @default("")
  economicCode String   @default("")
  regNo        String   @default("")
  phone        String   @default("")
  fax          String   @default("")
  address      String   @default("")
  postalCode   String   @default("")
  city         String   @default("")
  website      String   @default("")
  email        String   @default("")
  updatedAt    DateTime @updatedAt

  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
}

model FiscalYear {
  id         String   @id @default(cuid())
  businessId String
  label      String
  startDate  String
  endDate    String
  isActive   Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@index([businessId])
}

model AccountingProject {
  id         String   @id @default(cuid())
  businessId String
  name       String
  isDefault  Boolean  @default(false)
  active     Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@index([businessId])
}
