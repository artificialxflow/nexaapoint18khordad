generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum UserStatus {
  active
  disabled
}

enum InviteCredentialMode {
  self
  manual
  auto
}

enum AccessLevelPreset {
  full
  sales_only
  finance_only
  custom
}

enum BusinessPlan {
  trial
  active
}

enum BusinessMemberRole {
  owner
  admin
  member
}

enum BusinessStatus {
  active
  archived
}

enum MeizitoApprovalState {
  draft
  pending
  approved
  rejected
  cancelled
}

enum MeizitoApprovalAction {
  approve
  reject
  forward
  comment
  submit
  cancel
}

enum MeizitoMemberRole {
  member
  manager
  senior_manager
}

model SystemRole {
  id          String   @id @default(cuid())
  slug        String   @unique
  nameFa      String
  level       Int
  permissions Json
  isSystem    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  users        User[]
  inviteTokens InviteToken[]
}

model User {
  id                 String            @id @default(cuid())
  username           String            @unique
  passwordHash       String
  displayName        String
  status             UserStatus        @default(active)
  systemRoleId       String
  createdById        String?
  mustChangePassword Boolean           @default(false)
  accessLevelPreset  AccessLevelPreset @default(custom)
  lastLoginAt        DateTime?
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt

  systemRole SystemRole @relation(fields: [systemRoleId], references: [id])
  createdBy  User?      @relation("UserCreatedBy", fields: [createdById], references: [id])
  createdUsers User[]   @relation("UserCreatedBy")

  sessions        Session[]
  invitesCreated  InviteToken[]    @relation("InviteCreatedBy")
  invitesConsumed InviteToken[]    @relation("InviteUsedBy")
  restriction     UserRestriction?
  bankAccess      UserBankAccess[]
  auditLogs       AdminAuditLog[]
  businessesCreated Business[]       @relation("BusinessCreatedBy")
  businessMembers   BusinessMember[]
  managedMemberProfiles BusinessMemberProfile[] @relation("MemberManager")
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  tokenHash String   @unique
  expiresAt DateTime
  ip        String?
  userAgent String?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model InviteToken {
  id                 String               @id @default(cuid())
  tokenHash          String               @unique
  systemRoleId       String
  createdById        String
  expiresAt          DateTime
  usedAt             DateTime?
  usedByUserId       String?
  note               String?
  displayName        String?
  credentialMode     InviteCredentialMode @default(self)
  presetUsername     String?
  presetPasswordHash String?
  createdAt          DateTime             @default(now())

  systemRole SystemRole @relation(fields: [systemRoleId], references: [id])
  createdBy  User       @relation("InviteCreatedBy", fields: [createdById], references: [id])
  usedBy     User?      @relation("InviteUsedBy", fields: [usedByUserId], references: [id])

  @@index([expiresAt])
  @@index([createdById])
}

model PermissionCatalog {
  id        String  @id @default(cuid())
  key       String  @unique
  labelFa   String
  module    String
  sortOrder Int     @default(0)
  isSystem  Boolean @default(true)
}

model UserRestriction {
  id                String   @id @default(cuid())
  userId            String   @unique
  ownSalesOnly      Boolean  @default(false)
  ownPurchaseOnly   Boolean  @default(false)
  timeWindowEnabled Boolean  @default(false)
  allowedFrom       String?
  allowedTo         String?
  updatedAt         DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model BankAccount {
  id        String   @id @default(cuid())
  nameFa    String
  code      String   @unique
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  userAccess UserBankAccess[]
}

model UserBankAccess {
  id            String   @id @default(cuid())
  userId        String
  bankAccountId String
  allowed       Boolean  @default(true)
  updatedAt     DateTime @updatedAt

  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  bankAccount BankAccount @relation(fields: [bankAccountId], references: [id], onDelete: Cascade)

  @@unique([userId, bankAccountId])
  @@index([userId])
}

model AdminAuditLog {
  id         String   @id @default(cuid())
  actorId    String
  action     String
  targetType String
  targetId   String?
  meta       Json?
  createdAt  DateTime @default(now())

  actor User @relation(fields: [actorId], references: [id], onDelete: Cascade)

  @@index([actorId])
  @@index([createdAt])
}

model Business {
  id            String         @id @default(cuid())
  name          String
  plan          BusinessPlan   @default(trial)
  expiresAt     DateTime?
  creditLabel   String         @default("نامحدود")
  defaultLocale String         @default("fa")
  status        BusinessStatus @default(active)
  createdById   String
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  createdBy   User                @relation("BusinessCreatedBy", fields: [createdById], references: [id])
  members     BusinessMember[]
  profile     BusinessProfile?
  fiscalYears FiscalYear[]
  projects    AccountingProject[]
  workspaceBoards  WorkspaceBoard[]
  workspaceCards   WorkspaceCard[]
  workspaceProjects WorkspaceProject[]
  noteBoards       NoteBoard[]
  workspaceNotes   WorkspaceNote[]
  dailyReports     DailyReport[]
  fieldVisits      FieldVisit[]
  internalRequests InternalRequest[]
  internalLetters    InternalLetter[]
  meizitoCalendars   MeizitoCalendar[]
  meizitoCalendarEvents MeizitoCalendarEvent[]
  chatThreads        ChatThread[]
  chatMessages       ChatMessage[]

  @@index([status])
  @@index([createdById])
}

model BusinessMember {
  id         String             @id @default(cuid())
  businessId String
  userId     String
  role       BusinessMemberRole @default(member)
  createdAt  DateTime           @default(now())

  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  profile  BusinessMemberProfile?

  @@unique([businessId, userId])
  @@index([userId])
}

model BusinessMemberProfile {
  memberId      String            @id
  jobTitle      String            @default("")
  department    String            @default("")
  mobile        String            @default("")
  extension     String            @default("")
  managerUserId String?
  meizitoRole   MeizitoMemberRole @default(member)
  updatedAt     DateTime          @updatedAt

  member  BusinessMember @relation(fields: [memberId], references: [id], onDelete: Cascade)
  manager User?          @relation("MemberManager", fields: [managerUserId], references: [id], onDelete: SetNull)

  @@index([managerUserId])
  @@index([department])
}

model BusinessProfile {
  businessId   String   @id
  legalName    String   @default("")
  tradeName    String   @default("")
  nationalId   String   @default("")
  economicCode String   @default("")
  regNo        String   @default("")
  phone        String   @default("")
  fax          String   @default("")
  address      String   @default("")
  postalCode   String   @default("")
  city         String   @default("")
  website      String   @default("")
  email        String   @default("")
  updatedAt    DateTime @updatedAt

  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
}

model FiscalYear {
  id         String   @id @default(cuid())
  businessId String
  label      String
  startDate  String
  endDate    String
  isActive   Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@index([businessId])
}

model AccountingProject {
  id         String   @id @default(cuid())
  businessId String
  name       String
  isDefault  Boolean  @default(false)
  active     Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@index([businessId])
}

enum DailyReportStatus {
  draft
  submitted
}

enum MeizitoRecurrenceKind {
  none
  daily
  weekly
}

model WorkspaceBoard {
  id           String   @id @default(cuid())
  businessId   String
  name         String
  memberNames  Json     @default("[]")
  labelPalette Json     @default("[]")
  sortOrder    Int      @default(0)
  createdById  String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  business Business          @relation(fields: [businessId], references: [id], onDelete: Cascade)
  columns  WorkspaceColumn[]
  cards    WorkspaceCard[]

  @@index([businessId])
}

model WorkspaceColumn {
  id      String @id @default(cuid())
  boardId String
  title   String
  order   Int
  cardIds Json   @default("[]")

  board WorkspaceBoard @relation(fields: [boardId], references: [id], onDelete: Cascade)

  @@index([boardId])
}

model WorkspaceCard {
  id             String                @id @default(cuid())
  businessId     String
  boardId        String
  columnId       String
  title          String
  description    String                @default("")
  labelIds       Json                  @default("[]")
  category       String                @default("")
  assigneeUserId String?
  assignee       String                @default("")
  checklist      Json                  @default("[]")
  attachments    Json                  @default("[]")
  dueDate        String                @default("")
  dueTime        String                @default("")
  recurrence     MeizitoRecurrenceKind @default(none)
  starred        Boolean               @default(false)
  sortOrder      Int                   @default(0)
  createdAt      DateTime              @default(now())
  updatedAt      DateTime              @updatedAt

  business Business       @relation(fields: [businessId], references: [id], onDelete: Cascade)
  board    WorkspaceBoard @relation(fields: [boardId], references: [id], onDelete: Cascade)

  @@index([businessId])
  @@index([boardId])
  @@index([columnId])
}

model WorkspaceProject {
  id           String   @id @default(cuid())
  businessId   String
  name         String
  boardId      String?
  ncFolderPath String?
  memberIds    Json     @default("[]")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@index([businessId])
}

model NoteBoard {
  id         String @id @default(cuid())
  businessId String
  name       String
  color      String @default("#94a3b8")
  order      Int    @default(0)

  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@index([businessId])
}

model WorkspaceNote {
  id            String   @id @default(cuid())
  businessId    String
  boardId       String
  title         String
  content       String   @default("")
  color         String   @default("#fef08a")
  checklist     Json     @default("[]")
  ncAttachments Json     @default("[]")
  starred       Boolean  @default(false)
  archived      Boolean  @default(false)
  deletedAt     String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@index([businessId])
  @@index([boardId])
}

model DailyReport {
  id                String            @id @default(cuid())
  businessId        String
  authorUserId      String
  authorName        String
  dateKey           String
  title             String            @default("")
  body              String            @default("")
  status            DailyReportStatus @default(draft)
  managerApproved   Boolean           @default(false)
  managerApprovedAt DateTime?
  feedbackEntries   Json              @default("[]")
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt

  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@index([businessId, dateKey])
  @@index([authorUserId])
}

model FieldVisit {
  id           String   @id @default(cuid())
  businessId   String
  authorUserId String
  authorName   String
  dateKey      String
  details      Json
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@index([businessId, dateKey])
}

enum InternalRequestStatus {
  open
  closed
}

enum InternalRequestPriority {
  low
  medium
  high
}

model InternalRequest {
  id                    String                  @id @default(cuid())
  businessId            String
  subject               String
  body                  String                  @default("")
  status                InternalRequestStatus   @default(open)
  priority              InternalRequestPriority @default(medium)
  category              String                  @default("")
  authorUserId          String
  authorName            String
  referredToUserIds     Json                    @default("[]")
  referredTo            Json                    @default("[]")
  ccUserIds             Json                    @default("[]")
  attachments           Json                    @default("[]")
  threadId              String?
  replyToRequestId      String?
  sourceChatMessageId   String?
  approvalState         MeizitoApprovalState    @default(draft)
  currentAssigneeUserId String?
  submittedAt           DateTime?
  closedAt              DateTime?
  createdAt             DateTime                @default(now())
  updatedAt             DateTime                @updatedAt

  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@index([businessId])
  @@index([businessId, status])
  @@index([authorUserId])
  @@index([currentAssigneeUserId])
  @@index([approvalState])
}

enum InternalLetterStatus {
  open
  closed
}

enum InternalLetterBox {
  inbox
  outbox
  archive
}

model InternalLetter {
  id                    String               @id @default(cuid())
  businessId            String
  subject               String
  body                  String               @default("")
  to                    Json                 @default("[]")
  labels                Json                 @default("[]")
  category              String               @default("other")
  status                InternalLetterStatus @default(open)
  box                   InternalLetterBox    @default(outbox)
  templateId            String?
  referredTo            Json                 @default("[]")
  referredFrom          String               @default("")
  authorUserId          String
  replyToLetterId       String?
  threadId              String?
  attachments           Json                 @default("[]")
  approvalState         MeizitoApprovalState @default(draft)
  currentAssigneeUserId String?
  submittedAt           DateTime?
  createdAt             DateTime             @default(now())
  updatedAt             DateTime             @updatedAt

  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@index([businessId])
  @@index([businessId, box])
  @@index([businessId, status])
  @@index([authorUserId])
  @@index([threadId])
  @@index([currentAssigneeUserId])
  @@index([approvalState])
}

enum MeizitoCalendarKind {
  customer_followup
  service
  general
  custom
}

model MeizitoCalendar {
  id          String              @id @default(cuid())
  businessId  String
  slug        String?
  name        String
  color       String
  kind        MeizitoCalendarKind @default(custom)
  sharedWith  Json                @default("[]")
  ownerUserId String
  ownerName   String
  visible     Boolean             @default(true)
  sortOrder   Int                 @default(0)
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt

  business Business               @relation(fields: [businessId], references: [id], onDelete: Cascade)
  events   MeizitoCalendarEvent[]

  @@unique([businessId, slug])
  @@index([businessId])
}

model MeizitoCalendarEvent {
  id              String   @id @default(cuid())
  businessId      String
  calendarId      String
  title           String
  dateKey         String
  time            String?
  sourceCardId    String?
  notes           String?
  reminderMinutes Int?
  attendeeIds     Json     @default("[]")
  rsvp            Json     @default("{}")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  business Business        @relation(fields: [businessId], references: [id], onDelete: Cascade)
  calendar MeizitoCalendar @relation(fields: [calendarId], references: [id], onDelete: Cascade)

  @@index([businessId])
  @@index([businessId, calendarId])
  @@index([businessId, dateKey])
  @@index([sourceCardId])
}

enum MeizitoThreadType {
  direct
  group
  channel
}

enum MeizitoMessageType {
  text
  file
  voice
  image
  video
}

model ChatThread {
  id               String            @id @default(cuid())
  businessId       String
  title            String
  threadType       MeizitoThreadType @default(direct)
  participantNames Json              @default("[]")
  starred          Boolean           @default(false)
  pinned           Boolean           @default(false)
  sortOrder        Int               @default(0)
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt

  business Business     @relation(fields: [businessId], references: [id], onDelete: Cascade)
  messages ChatMessage[]

  @@index([businessId])
  @@index([businessId, threadType])
}

model ChatMessage {
  id               String             @id @default(cuid())
  businessId       String
  threadId         String
  authorUserId     String?
  authorName       String
  body             String             @default("")
  type             MeizitoMessageType @default(text)
  attachmentNames  Json               @default("[]")
  attachmentRefs   Json               @default("[]")
  voiceDurationSec Int?
  editedAt         DateTime?
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt

  business Business   @relation(fields: [businessId], references: [id], onDelete: Cascade)
  thread   ChatThread @relation(fields: [threadId], references: [id], onDelete: Cascade)

  @@index([businessId])
  @@index([businessId, threadId])
  @@index([threadId])
}

model MeizitoApprovalStep {
  id               String                @id @default(cuid())
  businessId       String
  entityType       String
  entityId         String
  action           MeizitoApprovalAction
  actorUserId      String
  actorName        String
  assigneeUserId   String?
  comment          String?
  forwardedToIds   Json                  @default("[]")
  forwardedToNames Json                  @default("[]")
  createdAt        DateTime              @default(now())

  @@index([businessId, entityType, entityId])
  @@index([businessId, assigneeUserId])
  @@index([entityType, entityId])
}
