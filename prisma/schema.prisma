generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum UserStatus {
  active
  disabled
}

enum InviteCredentialMode {
  self
  manual
  auto
}

enum AccessLevelPreset {
  full
  sales_only
  finance_only
  custom
}

model SystemRole {
  id          String   @id @default(cuid())
  slug        String   @unique
  nameFa      String
  level       Int
  permissions Json
  isSystem    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  users        User[]
  inviteTokens InviteToken[]
}

model User {
  id                 String            @id @default(cuid())
  username           String            @unique
  passwordHash       String
  displayName        String
  status             UserStatus        @default(active)
  systemRoleId       String
  createdById        String?
  mustChangePassword Boolean           @default(false)
  accessLevelPreset  AccessLevelPreset @default(custom)
  lastLoginAt        DateTime?
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt

  systemRole SystemRole @relation(fields: [systemRoleId], references: [id])
  createdBy  User?      @relation("UserCreatedBy", fields: [createdById], references: [id])
  createdUsers User[]   @relation("UserCreatedBy")

  sessions        Session[]
  invitesCreated  InviteToken[]    @relation("InviteCreatedBy")
  invitesConsumed InviteToken[]    @relation("InviteUsedBy")
  restriction     UserRestriction?
  bankAccess      UserBankAccess[]
  auditLogs       AdminAuditLog[]
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  tokenHash String   @unique
  expiresAt DateTime
  ip        String?
  userAgent String?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model InviteToken {
  id                 String               @id @default(cuid())
  tokenHash          String               @unique
  systemRoleId       String
  createdById        String
  expiresAt          DateTime
  usedAt             DateTime?
  usedByUserId       String?
  note               String?
  displayName        String?
  credentialMode     InviteCredentialMode @default(self)
  presetUsername     String?
  presetPasswordHash String?
  createdAt          DateTime             @default(now())

  systemRole SystemRole @relation(fields: [systemRoleId], references: [id])
  createdBy  User       @relation("InviteCreatedBy", fields: [createdById], references: [id])
  usedBy     User?      @relation("InviteUsedBy", fields: [usedByUserId], references: [id])

  @@index([expiresAt])
  @@index([createdById])
}

model PermissionCatalog {
  id        String  @id @default(cuid())
  key       String  @unique
  labelFa   String
  module    String
  sortOrder Int     @default(0)
  isSystem  Boolean @default(true)
}

model UserRestriction {
  id                String   @id @default(cuid())
  userId            String   @unique
  ownSalesOnly      Boolean  @default(false)
  ownPurchaseOnly   Boolean  @default(false)
  timeWindowEnabled Boolean  @default(false)
  allowedFrom       String?
  allowedTo         String?
  updatedAt         DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model BankAccount {
  id        String   @id @default(cuid())
  nameFa    String
  code      String   @unique
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  userAccess UserBankAccess[]
}

model UserBankAccess {
  id            String   @id @default(cuid())
  userId        String
  bankAccountId String
  allowed       Boolean  @default(true)
  updatedAt     DateTime @updatedAt

  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  bankAccount BankAccount @relation(fields: [bankAccountId], references: [id], onDelete: Cascade)

  @@unique([userId, bankAccountId])
  @@index([userId])
}

model AdminAuditLog {
  id         String   @id @default(cuid())
  actorId    String
  action     String
  targetType String
  targetId   String?
  meta       Json?
  createdAt  DateTime @default(now())

  actor User @relation(fields: [actorId], references: [id], onDelete: Cascade)

  @@index([actorId])
  @@index([createdAt])
}
